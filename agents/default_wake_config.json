    "energy_saving": {
      "description": "节能模式",
      "config_template": {
        "max_wakeups_per_day": 2,
        "energy_threshold": 0.1,
        "strictness": 0.95
      },
      "suitable_for": ["配额紧张时", "非关键部门"]
    }
