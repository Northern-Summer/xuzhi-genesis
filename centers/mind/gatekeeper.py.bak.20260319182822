#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
OpenClaw 配置格式“守门员” (gatekeeper.py)
功能: 每日检查本地配置文件与官方最新配置格式的差异，并输出报告。
特性: 只读、不修改任何文件、不调用 doctor。
"""

import json
import os
import sys
import requests
from pathlib import Path
from datetime import datetime
import difflib
import re

# --- 配置区 ---
LOCAL_CONFIG_PATH = Path.home() / ".openclaw" / "openclaw.json"
# 官方参考配置的URL（这里假设官方提供一个最简但结构完整的示例文件）
# 如果官方没有直接提供，可以退而求其次，从文档中提取关键结构
OFFICIAL_REFERENCE_URL = "https://docs.openclaw.ai/zh-CN"  # 这个页面包含配置示例
# 或者，如果官方有更直接的JSON文件，请替换为以下URL:
# OFFICIAL_REFERENCE_URL = "https://docs.openclaw.ai/sample-config/openclaw.json"

# 定义需要关注的核心配置区块
CORE_SECTIONS = ["models", "agents", "gateway", "channels", "session", "tools", "hooks", "skills"]

# 颜色代码
GREEN = "\033[92m"
YELLOW = "\033[93m"
BLUE = "\033[94m"
RED = "\033[91m"
RESET = "\033[0m"
# --- 配置区结束 ---

def fetch_official_reference():
    """从官方源获取配置参考（优先使用GitHub示例，其次文档提取）"""
    # 官方GitHub示例配置URL（根据实际情况调整）
    GITHUB_RAW_URL = "https://raw.githubusercontent.com/openclaw/openclaw/main/config.example.json"
    # 文档URL（备用）
    DOCS_URL = "https://docs.openclaw.ai/zh-CN"

    try:
        print(f"{BLUE}📡 正在从GitHub获取官方示例配置...{RESET}")
        headers = {'User-Agent': 'Mozilla/5.0'}
        response = requests.get(GITHUB_RAW_URL, headers=headers, timeout=10)
        if response.status_code == 200:
            ref_config = response.json()
            print(f"{GREEN}✅ 成功从GitHub获取配置参考{RESET}")
            return ref_config
        else:
            print(f"{YELLOW}⚠️ GitHub获取失败，尝试从文档页面提取...{RESET}")
    except Exception as e:
        print(f"{YELLOW}⚠️ GitHub请求异常: {e}，尝试从文档提取...{RESET}")

    # 备用：从文档HTML提取JSON代码块
    try:
        print(f"{BLUE}📡 正在从文档页面提取配置...{RESET}")
        headers = {'User-Agent': 'Mozilla/5.0'}
        response = requests.get(DOCS_URL, headers=headers, timeout=10)
        response.encoding = 'utf-8'
        html = response.text

        # 查找JSON代码块
        json_pattern = r''
        matches = re.findall(json_pattern, html, re.DOTALL)
        if matches:
            ref_config = json.loads(matches[0])
            print(f"{GREEN}✅ 成功从文档提取配置参考{RESET}")
            return ref_config
        else:
            print(f"{YELLOW}⚠️ 文档中未找到JSON代码块{RESET}")
    except Exception as e:
        print(f"{YELLOW}⚠️ 文档提取失败: {e}{RESET}")

    # 最后备用：使用内置参考结构（明确告知用户）
    print(f"{YELLOW}⚠️ 所有在线源均失败，将使用内置参考结构（可能已过时）{RESET}")
    builtin_ref = {
        "models": {"mode": "merge", "providers": {}},
        "agents": {"defaults": {"model": {}, "workspace": ""}},
        "gateway": {"port": 18789, "mode": "local"},
        "channels": {"whatsapp": {"allowFrom": []}},
        "session": {"reset": {}},
        "tools": {"profile": "coding"}
    }
    return builtin_ref
def load_local_config():
    """加载本地配置文件"""
    try:
        if not LOCAL_CONFIG_PATH.exists():
            print(f"{RED}❌ 本地配置文件不存在: {LOCAL_CONFIG_PATH}{RESET}")
            return None
        with open(LOCAL_CONFIG_PATH, 'r', encoding='utf-8') as f:
            return json.load(f)
    except json.JSONDecodeError as e:
        print(f"{RED}❌ 本地配置文件格式错误: {e}{RESET}")
        return None

def compare_sections(local_config, ref_config):
    """比较核心配置区块的结构性差异"""
    print(f"\n{BLUE}🔍 开始对比核心配置区块...{RESET}\n")
    has_differences = False

    for section in CORE_SECTIONS:
        print(f"{YELLOW}▶ 检查区块: {section}{RESET}")
        local_section = local_config.get(section, {})
        ref_section = ref_config.get(section, {})

        # 如果本地没有这个区块，但参考有，说明可能遗漏了新功能
        if not local_section and ref_section:
            print(f"  {RED}⚠️ 缺失核心区块: {section} (官方推荐配置中已包含此部分){RESET}")
            has_differences = True
            continue

        # 如果参考中没有这个区块（比如它是自定义的），跳过
        if not ref_section:
            print(f"  {GREEN}✅ 区块 {section} 为自定义配置，不参与对比{RESET}")
            continue

        # 检查一级键的差异
        local_keys = set(local_section.keys())
        ref_keys = set(ref_section.keys())

        new_keys = ref_keys - local_keys
        if new_keys:
            print(f"  {YELLOW}✨ 官方新增推荐键: {', '.join(new_keys)}{RESET}")
            has_differences = True

        # 检查可能的废弃键（本地有，但官方参考里没有，需要人工确认）
        extra_keys = local_keys - ref_keys
        if extra_keys:
            print(f"  {BLUE}📌 本地有但官方参考未明确列出的键 (可能为自定义或已废弃): {', '.join(extra_keys)}{RESET}")
            # 这不算错误，但提醒用户留意
            has_differences = True  # 标记为有差异，让用户注意

        # 针对 models.providers 的特殊检查（你关心的多提供商）
        if section == "models" and "providers" in local_section:
            local_providers = local_section["providers"]
            # 检查每个提供商的必备字段（基于官方 OpenAI 兼容格式要求）
            required_provider_keys = ["baseUrl", "api", "models"]
            for provider_name, provider_config in local_providers.items():
                missing_keys = [k for k in required_provider_keys if k not in provider_config]
                if missing_keys:
                    print(f"  {RED}❌ 提供商 '{provider_name}' 缺少必备键: {', '.join(missing_keys)}{RESET}")
                    has_differences = True
                # 检查 baseUrl 是否以 /v1 结尾
                if "baseUrl" in provider_config and not provider_config["baseUrl"].endswith("/v1"):
                    print(f"  {YELLOW}⚠️ 提供商 '{provider_name}' 的 baseUrl 可能应以 '/v1' 结尾 (当前: {provider_config['baseUrl']}){RESET}")
                    has_differences = True

        # 如果双方都有，且没有新增键，显示正常
        if not new_keys and not extra_keys:
            print(f"  {GREEN}✅ 区块结构一致{RESET}")

    return has_differences

def main():
    print(f"{BLUE}========================================{RESET}")
    print(f"{BLUE}   OpenClaw 配置格式“守门员” v1.0{RESET}")
    print(f"{BLUE}   只读模式 | 绝不修改 | {datetime.now().strftime('%Y-%m-%d')}{RESET}")
    print(f"{BLUE}========================================{RESET}")

    # 1. 获取官方参考
    ref_config = fetch_official_reference()
    if not ref_config:
        print(f"{RED}❌ 无法获取官方配置参考，请检查网络。{RESET}")
        sys.exit(1)

    # 2. 加载本地配置
    local_config = load_local_config()
    if not local_config:
        sys.exit(1)

    # 3. 显示本地OpenClaw版本（如果有）
    if "meta" in local_config and "lastTouchedVersion" in local_config["meta"]:
        print(f"{GREEN}📋 本地OpenClaw版本: {local_config['meta']['lastTouchedVersion']}{RESET}")

    # 4. 对比配置
    differences_found = compare_sections(local_config, ref_config)

    # 5. 输出总结和建议
    print(f"\n{BLUE}========================================{RESET}")
    if differences_found:
        print(f"{YELLOW}⚠️  检测到配置格式差异！{RESET}")
        print(f"{YELLOW}建议：{RESET}")
        print(f"  1. 以上提示仅为参考，不代表配置错误。")
        print(f"  2. 如果官方新增了推荐配置，你可以考虑手动添加到 {LOCAL_CONFIG_PATH}")
        print(f"  3. 如果提示了废弃键，请查阅官方文档确认是否需要清理。")
        print(f"  4. 你的配置仍然有效，可以继续使用。")
    else:
        print(f"{GREEN}✅ 恭喜！你的配置文件结构与官方推荐完全一致！{RESET}")
        print(f"{GREEN}   继续保持，这是最稳妥的方式。{RESET}")

    # 6. 可选：通过OpenClaw自己发送通知（如果你想让它在聊天里提醒你）
    # 这需要调用 openclaw execute 命令，但不属于本脚本的强制功能
    print(f"\n{BLUE}📢 如需每日在聊天中接收此报告，可将此脚本加入开机自启。{RESET}")
    show_social_ratings()

def show_social_ratings():
    """显示当前社会评价（只读）"""
    ratings_file = Path.home() / ".openclaw" / "centers" / "mind" / "society" / "ratings.json"
    if ratings_file.exists():
        try:
            with open(ratings_file, "r", encoding="utf-8") as f:
                data = json.load(f)
            print(f"\n{BLUE}========================================{RESET}")
            print(f"{BLUE}          当前社会评价状态          {RESET}")
            print(f"{BLUE}========================================{RESET}")
            agents = data.get("agents", {})
            if agents:
                # 按分数排序
                sorted_agents = sorted(agents.items(), key=lambda x: x[1].get("score", 0), reverse=True)
                for agent_id, info in sorted_agents:
                    score = info.get("score", 0)
                    print(f"  {agent_id}: {GREEN}{score}{RESET}")
                print(f"\n最后更新: {data.get("last_updated", 未知)}")
            else:
                print(f"  {YELLOW}暂无智能体评价{RESET}")
        except Exception as e:
            print(f"{RED}读取评价失败: {e}{RESET}")
    else:
        print(f"{YELLOW}评价文件不存在{RESET}")



