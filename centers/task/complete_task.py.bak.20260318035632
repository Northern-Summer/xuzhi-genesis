#!/usr/bin/env python3
"""
标记任务为完成。
- 合作模式：任何参与者完成，所有参与者都视为完成者。
- 竞争模式：只允许一个完成者（调用者），其他参与者视为未完成。
用法: ./complete_task.py <task_id> <agent_id>
"""
import json
import sys
from pathlib import Path
from datetime import datetime

TASKS_JSON = Path.home() / ".openclaw" / "tasks" / "tasks.json"

def main():
    if len(sys.argv) != 3:
        print("用法: complete_task.py <task_id> <agent_id>")
        sys.exit(1)

    task_id = int(sys.argv[1])
    agent_id = sys.argv[2]

    with open(TASKS_JSON) as f:
        data = json.load(f)

    task = None
    for t in data["tasks"]:
        if t["id"] == task_id:
            task = t
            break

    if not task:
        print(f"❌ 未找到任务 {task_id}")
        sys.exit(1)

    if task.get("status") not in ("进行", "竞争"):
        print(f"❌ 任务 {task_id} 状态不是'进行'，当前: {task.get('status')}")
        sys.exit(1)

    participants = task.get("participants", [])
    if agent_id not in participants:
        print(f"❌ {agent_id} 不是任务 {task_id} 的参与者")
        sys.exit(1)

    mode = task.get("mode", "competition")  # 默认竞争

    if mode == "cooperation":
        # 合作模式：所有参与者都视为完成者
        task["completed_by"] = participants[:]
        task["status"] = "完成"
        task["completion_time"] = datetime.now().isoformat()
        print(f"✅ 合作任务 {task_id} 已完成，所有参与者共同完成: {participants}")
    else:  # competition
        # 竞争模式：只有调用者完成，其他参与者保持原状（但任务完成，他们视为失败）
        task["completed_by"] = [agent_id]
        task["status"] = "完成"
        task["completion_time"] = datetime.now().isoformat()
        print(f"✅ 竞争任务 {task_id} 已完成，完成者: {agent_id}")

    task["last_updated"] = datetime.now().isoformat()

    with open(TASKS_JSON, 'w') as f:
        json.dump(data, f, indent=2)

if __name__ == "__main__":
    main()
